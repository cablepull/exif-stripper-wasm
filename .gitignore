# Generated by Cargo — compiled artifacts and executables
debug/
target/

# rustfmt backups
**/*.rs.bk

# MSVC Windows debug symbols
*.pdb

# wasm-pack output (regenerate: wasm-pack build --target web [--release])
/pkg/

# Front-end (www/)
www/node_modules/
www/dist/
www/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# spec-check MCP — local metrics / storage (see spec-check.config.json metrics.db_path)
.spec-check/data/

# Environment and secrets
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# Editors / IDEs
.idea/
*.swp
*.swo
*~

# Claude Code — machine-local settings (project instructions stay in committed files)
.claude/settings.local.json

# RustRover — full template: https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
# Uncomment to ignore all JetBrains project metadata:
#.idea/
